# Dependencies
node_modules/
.pnpm-store/
.npm-cache/

# Build outputs
dist/
build/
*.tsbuildinfo
frontend/vite.config.d.ts
frontend/vite.config.js
frontend/uno.config.d.ts
frontend/uno.config.js

# 但是！shared 是 workspace lib，dist 是各端运行时实际 import 的产物，
# 必须入 git，否则 EAS local build / 部署时 metro 找不到。
!shared/dist/
!shared/dist/**

# Release products（本地打包出的部署产物，按需手动上传到服务器，不入库）
/dist-release/

# Runtime（仅忽略 backend 运行时生成的存储与数据库目录，
# 注意要带前导 /，否则会误伤 backend/src/infra/storage/ 源码目录）
/backend/storage/
/backend/data/
*.db
*.db-journal
*.db-wal
*.db-shm

# Logs
*.log
logs/

# Env
.env
.env.local
.env.*.local

# IDE
.vscode/*
!.vscode/extensions.json
.idea/

# OS
.DS_Store
Thumbs.db

# 用户提供的原图素材（已复制到 app/assets，无需重复入库）
/9c6ec2b2-6d3f-4a68-990f-5dc82ea0e264.png

# 小程序构建产物（dist 是 Taro 编译输出，不 track）
/miniapp/dist/

# Test
coverage/

# 防止 tsc 误把 shared/src/*.ts 编译产出 .js 进 src
shared/src/**/*.js
shared/src/**/*.d.ts

{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "dist",
    "rootDir": "src",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "types": ["node"],
    "paths": {
      "@photo/shared": ["../shared/src/index.ts"],
      "@photo/shared/*": ["../shared/src/*"]
    },
    "noUncheckedIndexedAccess": false
  },
  "include": ["src/**/*", "drizzle.config.ts"]
}

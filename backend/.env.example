# 服务端口
PORT=3000
HOST=0.0.0.0

# 运行环境
NODE_ENV=development

# JWT 秘钥（生产环境务必更换为强随机字符串）
JWT_ACCESS_SECRET=dev-access-secret-please-change-me-in-production-32chars
JWT_REFRESH_SECRET=dev-refresh-secret-please-change-me-in-production-32chars

# 数据库与存储路径（相对项目根目录）
DB_PATH=../data/app.db
STORAGE_DIR=../storage

# CORS 允许的前端地址
CORS_ORIGIN=http://localhost:5173

# 是否使用 HTTPS Cookie（生产环境置 1）
COOKIE_SECURE=0

# 服务端口
PORT=3000
HOST=0.0.0.0

# 运行环境
NODE_ENV=development

# JWT 秘钥（生产环境必填，长度 ≥ 32；缺失或过短将导致进程退出）
JWT_ACCESS_SECRET=dev-access-secret-please-change-me-in-production-32chars
JWT_REFRESH_SECRET=dev-refresh-secret-please-change-me-in-production-32chars

# 数据库与存储路径（相对项目根目录）
DB_PATH=../data/app.db
STORAGE_DIR=../storage

# CORS 允许的前端地址（多个用逗号分隔）。开发模式额外放行 localhost/局域网。
CORS_ORIGIN=http://localhost:5173

# 受信代理 IP（白名单形式，多个逗号分隔）。
# 仅当请求来自这些 IP/CIDR 时才解析 X-Forwarded-For；
# 缺省一律视为 false，避免 req.ip 被伪造。
# 例：TRUSTED_PROXY_IPS=127.0.0.1,10.0.0.0/8
# TRUSTED_PROXY_IPS=

# 是否使用 HTTPS Cookie（生产环境置 1）
COOKIE_SECURE=0

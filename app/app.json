{
  "expo": {
    "name": "Dolmo Photo",
    "slug": "dolmo-photo",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "dolmophoto",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "top.dolmo.photo",
      "infoPlist": {
        "NSCameraUsageDescription": "需要相机权限用于扫描分享码二维码",
        "NSPhotoLibraryUsageDescription": "需要相册权限以保存图片到您的相册",
        "NSPhotoLibraryAddUsageDescription": "需要相册写入权限以保存图片",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#ffffff"
      },
      "package": "top.dolmo.photo",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_VISUAL_USER_SELECTED",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.READ_MEDIA_AUDIO"
      ]
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash.png",
          "backgroundColor": "#2563eb",
          "resizeMode": "contain",
          "imageWidth": 200
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "需要相机权限用于扫描分享码二维码"
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "需要相册权限以保存图片到您的相册",
          "savePhotosPermission": "需要相册权限以保存图片到您的相册",
          "isAccessMediaLocationEnabled": false
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "需要相册权限以选择图片上传"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "apiBaseUrl": "https://www.dolmo.top",
      "router": {},
      "eas": {
        "projectId": "af34c5f7-3826-4256-892e-ffabf95e95ca"
      }
    }
  }
}
